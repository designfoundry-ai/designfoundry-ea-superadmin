# DesignFoundry Super Admin Console — Environment Variables

# Main platform API base URL.
#
# - Production / staging: set to the rezonator backend URL,
#   e.g. https://api.designfoundry.ai/api/v1
#
# - Local development: leave UNSET (or empty). When unset, the frontend
#   falls through to the local /api/superadmin/* Next.js routes which
#   query Postgres directly and accept dev credentials
#   (super@designfoundry.app / superadmin123). Setting this to a
#   production URL during local dev causes login attempts to hit
#   production and fail.
NEXT_PUBLIC_API_URL=

# Optional: Backend auth for server-side requests
API_SECRET_TOKEN=your-superadmin-secret

# Redis URL (optional — for caching dashboard KPIs)
REDIS_URL=redis://localhost:6379

# Superadmin's own dedicated PostgreSQL database (separate from any EA instance DB)
ADMIN_DATABASE_URL=postgresql://design_foundry:design_foundry@localhost:5432/designfoundry_admin

# AES-256-GCM master key for encrypting per-instance API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INSTANCE_CREDENTIALS_KEY=

# Node environment
NODE_ENV=development
